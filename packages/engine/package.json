{
  "name": "@ahcf-cps/engine",
  "version": "0.1.0",
  "description": "Calculation engine for the Adaptive Human-Centered Framework for Cobot Programming Selection (AHCF-CPS).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx src/bench.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint handled at root)\" && exit 0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
