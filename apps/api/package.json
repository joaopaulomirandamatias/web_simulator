{
  "name": "@ahcf-cps/api",
  "version": "0.1.0",
  "description": "REST API for the AHCF-CPS Web Simulator (Fastify + TypeScript).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint handled at root)\" && exit 0",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "verify:openrouter": "tsx scripts/verify-openrouter.ts",
    "test:openrouter-models": "tsx scripts/test-openrouter-models.ts",
    "openrouter:stream-example": "tsx scripts/openrouter-stream-example.ts"
  },
  "dependencies": {
    "@ahcf-cps/engine": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/static": "^8.3.0",
    "@openrouter/sdk": "^0.12.20",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
