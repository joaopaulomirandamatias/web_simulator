{
  "name": "@ahcf-cps/web",
  "version": "0.1.0",
  "description": "Tablet-oriented web UI for the AHCF-CPS Web Simulator.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "echo \"(unit tests pending; e2e: pnpm e2e)\" && exit 0",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(lint handled at root)\" && exit 0"
  },
  "dependencies": {
    "@ahcf-cps/engine": "workspace:*",
    "@tanstack/react-query": "^5.59.16",
    "clsx": "^2.1.1",
