# AHCF-CPS Web Simulator — environment variables (example)
# Copy to .env and fill values for local development.

# ---------- API ----------
PORT=3333
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Store backend: "memory" (default) or "prisma".
# Use "prisma" after running `pnpm --filter @ahcf-cps/api prisma:migrate`.
STORE_BACKEND=memory

# ---------- Web ----------
VITE_API_URL=http://localhost:3333

# ---------- Database (PostgreSQL, used by Prisma) ----------
# Default matches docker-compose.yml defaults.
DATABASE_URL=postgresql://ahcf_cps:ahcf_cps@localhost:5432/ahcf_cps?schema=public

# ---------- Authentication (optional, Sprint 2) ----------
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_EXPIRES_IN=12h
AUTH_ENABLED=false

# ---------- Explainability (academic validation feature) ----------
# When `false`, the API ignores trace requests and the Web hides the toggle.
# This allows community forks to ship a slimmer production build.
EXPLAIN_ENABLED=true
VITE_EXPLAIN_ENABLED=true

# ---------- AI test mode (OpenRouter) ----------
# Opt-in integration. When `AI_ENABLED=true` AND `OPENROUTER_API_KEY` is set,
# three endpoints (/api/v1/ai/explain, /suggest-strategy, /generate-simulation)
# become available. The Web toggle in Preferences is only visible when both
# the build flag and the API flag are on.
AI_ENABLED=false
OPENROUTER_API_KEY=
# Roteador gratuito (recomendado p/ :free) ou id fixo, ex. openai/gpt-oss-20b:free
OPENROUTER_MODEL=openrouter/free
OPENROUTER_REFERER=https://ahcf-cps.example
OPENROUTER_TITLE=AHCF-CPS Web Simulator
# 60s por tentativa; com 429 o backend reintenta (backoff) — ver OPENROUTER_MAX_RETRIES
OPENROUTER_TIMEOUT_MS=60000
# Retentativas em 429/529 (fornecedor saturado)
OPENROUTER_MAX_RETRIES=4
OPENROUTER_RETRY_BASE_MS=2000

# Web build flag for the AI test mode (hide the toggle entirely when false).
VITE_AI_ENABLED=true
