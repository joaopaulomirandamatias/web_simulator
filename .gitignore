# ============================================================
# AHCF-CPS Web Simulator — .gitignore
# ============================================================

# -------- Internal project documentation (not versioned) ----
doc/
/doc
**/doc/

# -------- Node / JavaScript / TypeScript --------------------
node_modules/
.pnp/
.pnp.js
.yarn/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------- Build output --------------------------------------
dist/
build/
out/
.next/
.nuxt/
.turbo/
.vite/
coverage/
.nyc_output/
*.tsbuildinfo

# -------- Environment / secrets -----------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt

# -------- Logs ----------------------------------------------
logs/
*.log

# -------- OS / Editor ---------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo

# -------- Database / local state ----------------------------
*.sqlite
*.sqlite3
*.db
prisma/migrations/dev.db*
docker-data/

# -------- Claude Code / agents / scratch --------------------
.claude/
.cache/
tmp/
temp/

# -------- Python (scripts auxiliares, caso existam) ---------
__pycache__/
*.pyc
.venv/
venv/
